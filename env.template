# Copy this file to .env on the server (or let deploy-itguy.ps1 create .env from this template).
# cPanel MySQL: use DB credentials from cPanel → MySQL® Databases (user attached to database).

PORT=3000
DB_TYPE=mysql

DB_HOST=localhost
DB_NAME=your_cpanel_database_name
DB_USER=your_cpanel_database_user
DB_PASSWORD=your_database_password

# Optional: email (Nodemailer)
# EMAIL_USER=
# EMAIL_PASS=
